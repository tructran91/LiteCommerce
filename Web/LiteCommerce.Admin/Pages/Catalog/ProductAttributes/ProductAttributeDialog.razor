@using MudBlazor
@using LiteCommerce.Admin.Models.Business.ProductAttributeGroup

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)"
                     Color="Color.Primary" />
            <MudText Typo="Typo.h6">
                @(IsEdit ? "Edit Attribute" : "Add New Attribute")
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValid" Class="pt-2">
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="Attribute Name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Required="true"
                          RequiredError="Attribute name cannot be empty"
                          MaxLength="100"
                          Counter="100"
                          Immediate="true"
                          Placeholder="Ex: Color, Size, Material..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Label"
                          FullWidth="true" />

            <MudSelect T="string"
                       @bind-Value="_groupId"
                       Label="Attribute Group"
                       Variant="Variant.Outlined"
                       Margin="Margin.Normal"
                       Required="true"
                       RequiredError="Please select a group"
                       Placeholder="Select a group"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Category"
                       FullWidth="true">
                @foreach (var group in Groups)
                {
                    <MudSelectItem Value="@group.Id">@group.Name</MudSelectItem>
                }
            </MudSelect>

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   OnClick="Cancel"
                   StartIcon="@Icons.Material.Filled.Close">
            Hủy
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   StartIcon="@Icons.Material.Filled.Save">
            @(IsEdit ? "Save Changes" : "Add New")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string? InitialId { get; set; } = null;
    [Parameter] public string InitialName { get; set; } = "";
    [Parameter] public string InitialGroupId { get; set; } = "";
    [Parameter] public List<ProductAttributeGroupResponse> Groups { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; } = false;

    private MudForm _form = null!;
    private bool _formValid;
    private string? _id = null;
    private string _name = "";
    private string _groupId = "";

    protected override void OnInitialized()
    {
        _id = InitialId;
        _name = InitialName;
        _groupId = InitialGroupId;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_formValid) return;

        MudDialog.Close(DialogResult.Ok(new ProductAttributeDialogResult
        {
            Id = _id,
            Name = _name.Trim(),
            GroupId = _groupId,
            IsEdit = IsEdit
        }));
    }

    public class ProductAttributeDialogResult
    {
        public string? Id { get; set; }
        public string Name { get; set; } = "";
        public string GroupId { get; set; } = "";
        public bool IsEdit { get; set; }
    }
}
