@page "/product-prices"
@using BlazorTable
@using LiteCommerce.Admin.Constants
@using LiteCommerce.Admin.Shared.Components
@using LiteCommerce.Admin.Models.Business.ProductPrice

<PageTitle>Product Prices</PageTitle>

<Breadcrumb Title="Product Prices" BreadcrumbItems="breadcrumb"></Breadcrumb>

@if (isLoading)
{
    <Loading></Loading>
}
else
{
    if (products.Count == 0)
    {
        <Alert Content="@SystemMessages.NoData"></Alert>
    }
    else
    {
        <div class="table-responsive">
            <Table TableItem="ProductPricingResponse" Items="products" PageSize="@AppConstants.PageSize" TableBodyClass="align-middle">
                <Column TableItem="ProductPricingResponse" Title="Product Name" Field="@(x => x.Name)" Sortable="true" Filterable="true">
                    <Template>
                        <a href="/products/edit/@context.Id" class="text-primary">@context.Name</a>
                    </Template>
                </Column>
                <Column TableItem="ProductPricingResponse" Title="Current Price" Field="@(x => x.Price)" Sortable="true" Width="150px">
                    <Template>
                        <input type="number" 
                               class="form-control form-control-sm @(context.HasPriceChanged ? "border-warning" : "")" 
                               @bind="context.Price"
                               @bind:event="oninput"
                               placeholder="Enter price"
                               step="0.01" />
                    </Template>
                </Column>
                <Column TableItem="ProductPricingResponse" Title="Old Price" Field="@(x => x.OldPrice)" Sortable="true" Width="150px">
                    <Template>
                        <input type="number" 
                               class="form-control form-control-sm @(context.HasOldPriceChanged ? "border-warning" : "")" 
                               @bind="context.OldPrice"
                               @bind:event="oninput"
                               placeholder="Enter old price (optional)"
                               step="0.01" />
                    </Template>
                </Column>
                <Column TableItem="ProductPricingResponse" Title="Special Price" Field="@(x => x.SpecialPrice)" Sortable="true">
                    <Template>
                        <span>@(context.SpecialPrice?.ToString("N0") ?? "-")</span>
                    </Template>
                </Column>
                <Column TableItem="ProductPricingResponse" Title="Start" Field="@(x => x.SpecialPriceStart)" Sortable="true">
                    <Template>
                        <span>@(context.SpecialPriceStart?.ToString("g") ?? "-")</span>
                    </Template>
                </Column>
                <Column TableItem="ProductPricingResponse" Title="End" Field="@(x => x.SpecialPriceEnd)" Sortable="true">
                    <Template>
                        <span>@(context.SpecialPriceEnd?.ToString("g") ?? "-")</span>
                    </Template>
                </Column>
                <Pager ShowPageNumber="true" ShowTotalCount="true" />
            </Table>
        </div>

        <div class="d-flex justify-content-end mt-3">
            <button type="button" 
                    class="justify-content-center d-flex align-items-center btn btn-outline-primary"
                    @onclick="SavePricesAsync"
                    disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <i class="ti ti-device-floppy fs-5 me-2"></i>
                    <span>Save</span>
                }
            </button>
        </div>
    }
}