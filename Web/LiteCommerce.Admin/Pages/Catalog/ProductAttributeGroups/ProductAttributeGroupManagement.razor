@page "/product-attribute-groups"
@using LiteCommerce.Admin.Constants
@using LiteCommerce.Admin.Models.Business.ProductAttributeGroup

<PageTitle>Product Attribute Groups</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 pa-0" />

<!-- Page Header -->
<div class="d-flex align-center justify-space-between mb-5">
    <div>
        <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">Product Attribute Groups</MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => OpenAttributeGroupDialog(false))"
               Disabled="_loading">
        Add Attribute Group
    </MudButton>
</div>

<!-- Error Banner -->
@if (_errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
        <strong>@SystemMessages.ErrorOccurred</strong> @_errorMessage
        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadData" Class="ml-2">
            Try again
        </MudButton>
    </MudAlert>
}

<!-- Data Grid -->
<MudPaper Elevation="0" Class="rounded-lg overflow-hidden" Style="border:1px solid var(--mud-palette-divider)">
    <MudTable Items="@_allGroups"
              Hover="true"
              Dense="false"
              Elevation="0"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              SortLabel="Sort by"
              @ref="_table">

        <HeaderContent>
            <MudTh>
                <MudTableSortLabel T="ProductAttributeGroupResponse" SortBy="@(new Func<ProductAttributeGroupResponse, object>(x => x.Name))" SortDirectionChanged="OnSortChanged">Attribute Group Name</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:120px; text-align:center">Action</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="Attribute Group Name">
                <div class="d-flex align-center gap-3">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                               Style="font-size:0.75rem; font-weight:700">
                        @context.Name[0]
                    </MudAvatar>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Name</MudText>
                </div>
            </MudTd>
            <MudTd Style="text-align:center">
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => OpenAttributeGroupDialog(true, context))" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => OpenDeleteConfirm(context)" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <div class="pa-8 text-center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-3" Style="opacity:0.3" />
                <MudText Typo="Typo.body1" Class="mud-text-secondary">@SystemMessages.NoData</MudText>
            </div>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>