@using LiteCommerce.Admin.Models.Business.Product

<div class="mb-3 row align-items-center">
    <label class="form-label col-sm-2 col-form-label fw-semibold">Search Products</label>
    <div class="col-sm-10">
        <input type="text" class="form-control" placeholder="Type to filter products..."
               @bind="searchText" @bind:event="oninput" @bind:after="OnSearchTextChanged" />
    </div>
</div>

<div class="mb-4">
    <div class="list-group" style="max-height: 250px; overflow-y: auto;">
        @foreach (var product in FilteredProducts)
        {
            <button type="button"
                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                    @onclick="() => AddProduct(product)">
                <span>
                    @product.Name
                    @if (!product.IsPublished)
                    {
                        <span class="badge bg-warning ms-2">Draft</span>
                    }
                </span>
                <i class="ti ti-plus text-primary"></i>
            </button>
        }
        @if (FilteredProducts.Count == 0 && !string.IsNullOrWhiteSpace(searchText))
        {
            <div class="list-group-item text-muted text-center">No products found</div>
        }
    </div>
</div>

<hr />

<h6 class="fw-semibold mb-3 d-flex align-items-center gap-2">
    <i class="@Icon"></i>
    @Title
    @if (SelectedProducts.Count > 0)
    {
        <span class="badge bg-primary rounded-pill">@SelectedProducts.Count</span>
    }
</h6>

@if (SelectedProducts.Count == 0)
{
    <p class="text-muted">@EmptyMessage</p>
}
else
{
    <table class="table table-bordered table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>Product Name</th>
                <th style="width: 120px;" class="text-center">Status</th>
                <th style="width: 60px;" class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in SelectedProducts)
            {
                var productId = product.Id;
                <tr>
                    <td>@product.Name</td>
                    <td class="text-center">
                        @if (product.IsPublished)
                        {
                            <span class="badge bg-success">Published</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Draft</span>
                        }
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveProduct(productId)">
                            <i class="ti ti-x"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
