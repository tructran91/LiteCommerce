@using MudBlazor

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">Xác nhận xóa</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1">
            Bạn có chắc chắn muốn xóa <strong>"@ItemName"</strong> không?
        </MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">
            Hành động này không thể hoàn tác.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => MudDialog.Cancel())">
            Hủy
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))">
            Xóa
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string ItemName { get; set; } = "";
}
